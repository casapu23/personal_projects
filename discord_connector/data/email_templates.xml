<?xml version="1.0" encoding="utf-8" ?>
<odoo>
<data>

  <record id="email_template_link_not_configured_stock" model="mail.template">
    <field name="name">Stock link not configured or wrong</field>
    <field name="model_id" ref="stock.model_stock_warehouse_orderpoint"/>
    <field name="subject"> Stock link not configured/wrong "{{ object.name }}"</field>
    <field name="email_to">{{ object.user_id.email}}</field>
    <field name="body_html" type="html">
      <div style="margin: 0px; padding: 0px;">
        <p style="margin: 0px; padding: 0px; font-size: 13px;">
          Hello<span style="font-weight: bold;" t-out="object.user_id.name"/>
          ,
          <br/>
          <br/>
          Check in the configuration of the stock link. Maybe it's empty or wrong.
        </p>
      </div>
    </field>
    <field name="lang">{{ object.user_id.partner_id.lang or object.user_id.lang }}</field>
    <field name="auto_delete" eval="True"/>
  </record>

  <record id="email_template_link_not_configured_invoice" model="mail.template">
    <field name="name">Invoice link not configured or wrong</field>
    <field name="model_id" ref="account.model_account_move"/>
    <field name="subject">Invoice link not configured/wrong "{{ object.name }}"</field>
    <field name="email_to">{{ object.user_id.email }}</field>
    <field name="body_html" type="html">
      <div style="margin: 0px; padding: 0px;">
        <p style="margin: 0px; padding: 0px; font-size: 13px;">
          Hello <span style="font-weight: bold;" t-out="object.user_id.name"/>,
          <br/>
          <br/>
          Please check the configuration of the invoice link. It may be empty or incorrectly set up.
        </p>
      </div>
    </field>
    <field name="lang">{{ object.user_id.partner_id.lang or object.user_id.lang }}</field>
    <field name="auto_delete" eval="True"/>
  </record>

</data>
</odoo>