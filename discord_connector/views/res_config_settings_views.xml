<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_form_view_discord_connector" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.discord.connector</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='google_address_autocomplete']" position="after">
                <setting help="Connect with your sales discord channel" id="discord_sales_channel">
                    <field name="sales_channel_url"/>
                </setting>
                <setting help="Connect with your stock discord channel" id="discord_stock_channel">
                    <field name="stock_channel_url"/>
                </setting>
                <setting help="Connect with your accounting discord channel" id="discord_accounting_channel">
                    <field name="accounting_channel_url"/>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
